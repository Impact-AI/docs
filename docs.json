{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Impact AI",
  "appearance": {
    "default": "dark",
    "hideToggle": true
  },
  "background": {
    "color": {
      "dark": "#071735"
    }
  },
  "colors": {
    "primary": "#3BA7D1",
    "light": "#61D4F2",
    "dark": "#3BA7D1"
  },
  "favicon": "/favicon.png",
  "logo": {
    "light": "/images/logo.png",
    "dark": "/images/logo.png"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@impact.ai"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Platform",
      "href": "https://test.impact.ai"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "SDK",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "sdk/overview",
              "sdk/instrumentation",
              "sdk/best-practices"
            ]
          },
          {
            "group": "JavaScript SDK",
            "pages": [
              "sdk/javascript/setup",
              "sdk/javascript/initialize",
              "sdk/javascript/instrument",
              "sdk/javascript/integrations",
              "sdk/javascript/recipes",
              "sdk/javascript/api-reference"
            ]
          },
          {
            "group": "Python SDK",
            "pages": [
              "sdk/python/setup",
              "sdk/python/initialize",
              "sdk/python/instrument",
              "sdk/python/integrations",
              "sdk/python/recipes",
              "sdk/python/api-reference"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/impact-ai",
          "icon": "github"
        }
      ]
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/impact-ai"
    }
  },
  "analytics": {
    "posthog": {
      "apiKey": ""
    }
  },
  "feedback": {
    "thumbsRating": true,
    "suggestEdit": true
  }
}